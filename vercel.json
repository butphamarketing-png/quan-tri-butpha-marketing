{
  "version": 2,
  "buildCommand": "pnpm install && pnpm run build:api && pnpm run build:erp",
  "outputDirectory": "artifacts/erp/dist",
  "functions": {
    "artifacts/api-server/src/index.ts": {
      "runtime": "@vercel/node@3",
      "includeFiles": [
        "artifacts/api-server/src/**",
        "lib/**",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "package.json"
      ]
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/erp/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/erp/dist/index.html"
    }
  ]
}
