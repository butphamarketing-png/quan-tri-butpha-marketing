{
  "version": 2,
  "framework": null,
  "installCommand": "npm install -g pnpm@10.10.0 && pnpm install --no-frozen-lockfile --ignore-scripts",
  "buildCommand": "pnpm run build:api",
  "outputDirectory": "artifacts/api-server/dist",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    }
  ]
}
