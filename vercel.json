{
  "version": 2,
  "framework": null,
  "installCommand": "npm install -g pnpm@9.15.4 && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd artifacts/api-server && node build.mjs",
  "outputDirectory": "artifacts/api-server/dist",
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    }
  ]
}
